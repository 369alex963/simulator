# KERNELiOS backend — copy to .env and fill in all values.

# ── Django core ────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to false in production (default is false — must set true for local dev)
DJANGO_DEBUG=true

# Comma-separated list of allowed hostnames in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── CORS & CSRF ────────────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS + CSRF in production
DJANGO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Separate CSRF trusted origins (optional — defaults to DJANGO_CORS_ORIGINS if unset)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ── HTTPS / SSL (set in production behind nginx) ──────────────────────────
# Uncomment to disable Django's own SSL redirect (when nginx handles it):
# DJANGO_SSL_REDIRECT=false
# Initial HSTS duration (seconds). Start with 3600, then set to 31536000 once verified.
# DJANGO_HSTS_SECONDS=3600

# ── Database ───────────────────────────────────────────────────────────────
# Leave blank for SQLite (default dev). Set DB_ENGINE for PostgreSQL in production.
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=kernelios
# DB_USER=kernelios
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432
# DB_CONN_MAX_AGE=60
# DB_SSLMODE=prefer

# ── Redis (optional locally; recommended in production) ────────────────────
# REDIS_URL=redis://127.0.0.1:6379/0

# ── Email (Django settings — fallback if DB-stored SMTP is not configured) ─
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=noreply@kernelio.com

# ── File upload limits (bytes) ─────────────────────────────────────────────
# DJANGO_DATA_UPLOAD_MAX=5242880
# DJANGO_FILE_UPLOAD_MAX=5242880
